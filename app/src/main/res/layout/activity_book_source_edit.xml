<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <io.legado.app.ui.widget.TitleBar
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:title="@string/edit_book_source" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/space_xs"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="0dp"
        app:cardBackgroundColor="@color/background"
        app:cardCornerRadius="@dimen/radius_m"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_m"
            android:paddingVertical="0dp">

            <!--折叠头：始终显示一行摘要 + 箭头-->
            <LinearLayout
                android:id="@+id/ll_top_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minHeight="40dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_top_summary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:textColor="@color/primaryText"
                    tools:text="文本 · 已启用 · 发现" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/iv_top_arrow"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/expand_collapse"
                    android:src="@drawable/ic_arrow_down"
                    app:tint="@color/secondaryText" />

            </LinearLayout>

            <!--展开内容：类型下拉 + Chip 开关，默认折叠-->
            <LinearLayout
                android:id="@+id/ll_top_expand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!--书源类型-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/book_type"
                        android:textColor="@color/primaryText"
                        tools:ignore="RtlHardcoded" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/cg_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_m"
                        app:singleLine="true"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_type_text"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:text="@string/text" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_type_audio"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/audio" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_type_image"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Image" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_type_file"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="File" />

                    </com.google.android.material.chip.ChipGroup>

                </LinearLayout>

                <!--功能开关（自动换行的 Chip）-->
                <com.google.android.flexbox.FlexboxLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_s"
                    app:flexWrap="wrap">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/cb_is_enable"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/space_s"
                        android:checked="true"
                        android:text="@string/is_enable" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/cb_is_enable_explore"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/space_s"
                        android:checked="true"
                        android:text="@string/discovery" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/cb_is_enable_cookie"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/space_s"
                        android:checked="true"
                        android:text="@string/auto_save_cookie" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/cb_is_enable_review"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/space_s"
                        android:checked="false"
                        android:text="@string/review" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/cb_is_event_listener"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/space_s"
                        android:checked="false"
                        android:text="@string/is_event_listener" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/cb_is_custom_button"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/space_s"
                        android:checked="false"
                        android:text="@string/custom_button" />

                </com.google.android.flexbox.FlexboxLayout>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@color/background"
        android:elevation="2dp"
        tools:ignore="SpeakableTextPresentCheck" />

    <HorizontalScrollView
        android:id="@+id/field_nav_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/field_nav_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/space_xs"
            android:paddingVertical="@dimen/space_xs" />

    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        tools:listitem="@layout/item_source_edit" />

</LinearLayout>
